# Print Service Configuration

# Station ID
STATION_ID=ST01

# Printer Configuration
PRINTER_DRIVER=tspl              # tspl, zpl (future)
PRINTER_DEVICE=/dev/usb/lp0      # Linux: /dev/usb/lp0, Windows: LPT1 or network host
PRINTER_LABEL_WIDTH=50            # mm
PRINTER_LABEL_HEIGHT=30           # mm
PRINTER_DPI=203

# API Configuration
PRINT_API_PORT=5001

# Logging
LOG_LEVEL=info
