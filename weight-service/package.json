    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@serialport/binding-mock": "^10.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
