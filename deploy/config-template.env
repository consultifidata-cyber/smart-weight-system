# ============================================================
# Smart Weight System -- Station Configuration
# ============================================================
# Copy this file to the repo root as .env and fill in values.
#   copy deploy\config-template.env .env
#
# Each station MUST have a unique STATION_ID.
# Get the DJANGO_API_TOKEN from the Django admin panel
# (WeighStation table -> token field for this station).
# ============================================================

# -- Station Identity -----------------------------------------
STATION_ID=__STATION_ID__
PLANT_ID=__PLANT_ID__

# -- Weight Service (port 5000) -------------------------------
# Serial port where the weighing scale is connected.
# Find it: Device Manager -> Ports (COM & LPT) -> e.g. COM3
# SERIAL_PORT: set explicitly to lock to a specific COM port (e.g. COM3).
# Leave blank (commented out) to use SCALE_AUTO_DETECT instead.
SERIAL_PORT=__COM_PORT__
# SCALE_AUTO_DETECT=true  →  auto-pick the USB-serial adapter on startup.
#                             Ignored when SERIAL_PORT is set.
SCALE_AUTO_DETECT=false
# Phase E: if no weight data arrives for this many ms while port is open,
# force-close and reopen (fixes Windows USB Selective Suspend freeze).
# Set to 0 to disable. Default 15000 = 15 seconds.
SCALE_NO_DATA_TIMEOUT_MS=15000
SERIAL_BAUD_RATE=9600
SERIAL_DATA_BITS=8
SERIAL_PARITY=none
SERIAL_STOP_BITS=1
SIMULATE_SERIAL=false
WEIGHT_API_PORT=5000
STABILITY_THRESHOLD_MS=1500
STABILITY_TOLERANCE_KG=0.02
LOG_LEVEL=info

# -- Print Service (port 5001) --------------------------------
# PRINTER_DEVICE  = Windows shared printer name (for copy /b)
# PRINTER_NAME    = Full Windows printer name (for Get-Printer health check)
# Find them: Settings -> Printers -> right-click -> Properties
PRINTER_DRIVER=tspl
PRINTER_DEVICE=__PRINTER_SHARE_NAME__
PRINTER_NAME=__PRINTER_FULL_NAME__
PRINTER_LABEL_WIDTH=50
PRINTER_LABEL_HEIGHT=50
PRINTER_DPI=203
PRINT_API_PORT=5001

# -- Sync Service (port 5002) ---------------------------------
# DJANGO_SERVER_URL = URL of the central Django ERP server
# DJANGO_API_TOKEN  = Bearer token from WeighStation table
SYNC_API_PORT=5002
DJANGO_SERVER_URL=__DJANGO_URL__
DJANGO_API_TOKEN=__DJANGO_TOKEN__
SYNC_RETRY_INTERVAL_MS=60000
# Phase G: 5 minutes — new workers and FG items appear in the app within 5 min
# (was 1 hour). Set higher if server is slow or bandwidth is limited.
MASTER_SYNC_INTERVAL_MS=300000
SYNC_PUSH_TIMEOUT_MS=10000
BAG_SYNC_INTERVAL_MS=10000

# Offline fallback -- day_seq range for QR codes when Django is unreachable
OFFLINE_DAY_SEQ_START=90
OFFLINE_DAY_SEQ_END=99

# -- Web UI (port 3000) --------------------------------------
WEB_UI_PORT=3000

# -- Phase 1: Driverless printing (optional) ------------------
# PRINT_MODE=WINDOWS       → existing Windows spooler path (default, safe)
# PRINT_MODE=RAW_DIRECT    → bypass spooler, write raw TSPL/ZPL directly
#
# When PRINT_MODE=RAW_DIRECT:
#   PRINTER_INTERFACE=USB  → write to \\.\USBPRINxx (auto-detected, no driver needed)
#   PRINTER_INTERFACE=COM  → write to PRINTER_COM_PORT via serialport
#
# PRINTER_USB_DEVICE  leave blank for auto-detect, or set explicit path e.g. \\.\USBPRIN02
# PRINTER_COM_PORT    required only when PRINTER_INTERFACE=COM
PRINT_MODE=WINDOWS
PRINTER_INTERFACE=USB
PRINTER_AUTO_DETECT=false
PRINTER_USB_DEVICE=
PRINTER_COM_PORT=
# Phase 4: URL print-service uses to query scale status from weight-service
WEIGHT_SERVICE_URL=http://localhost:5000

# -- Multi-station dispatch (v2.2.1)
# Set true once Django endpoint /api/bags/<qr>/ is deployed.
# Default false = local-only dispatch (safe for single station).
DISPATCH_USE_DJANGO_LOOKUP=true
