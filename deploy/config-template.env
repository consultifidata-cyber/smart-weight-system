# ============================================================
# Smart Weight System — Station Configuration
# ============================================================
# Copy this file to the repo root as .env and fill in values.
#   copy deploy\config-template.env .env
#
# Each station MUST have a unique STATION_ID.
# Get the DJANGO_API_TOKEN from the Django admin panel
# (WeighStation table → token field for this station).
# ============================================================

# ── Station Identity ─────────────────────────────────────────
STATION_ID=__STATION_ID__
PLANT_ID=__PLANT_ID__

# ── Weight Service (port 5000) ───────────────────────────────
# Serial port where the weighing scale is connected.
# Find it: Device Manager → Ports (COM & LPT) → e.g. COM3
SERIAL_PORT=__COM_PORT__
SERIAL_BAUD_RATE=9600
SIMULATE_SERIAL=false
WEIGHT_API_PORT=5000
STABILITY_THRESHOLD_MS=1500
STABILITY_TOLERANCE_KG=0.02
LOG_LEVEL=info

# ── Print Service (port 5001) ────────────────────────────────
# PRINTER_DEVICE  = Windows shared printer name (for copy /b)
# PRINTER_NAME    = Full Windows printer name (for Get-Printer health check)
# Find them: Settings → Printers → right-click → Properties
PRINTER_DRIVER=tspl
PRINTER_DEVICE=__PRINTER_SHARE_NAME__
PRINTER_NAME=__PRINTER_FULL_NAME__
PRINTER_LABEL_WIDTH=50
PRINTER_LABEL_HEIGHT=50
PRINTER_DPI=203
PRINT_API_PORT=5001

# ── Sync Service (port 5002) ─────────────────────────────────
# DJANGO_SERVER_URL = URL of the central Django ERP server
# DJANGO_API_TOKEN  = Bearer token from WeighStation table
SYNC_API_PORT=5002
DJANGO_SERVER_URL=__DJANGO_URL__
DJANGO_API_TOKEN=__DJANGO_TOKEN__
SYNC_RETRY_INTERVAL_MS=60000
MASTER_SYNC_INTERVAL_MS=3600000
SYNC_PUSH_TIMEOUT_MS=10000
