# Station Configuration
STATION_ID=ST01

# Serial Port Configuration
SERIAL_PORT=COM4              # Windows: COM4, COM4, etc. | Linux: /dev/ttyUSB0
SERIAL_BAUD_RATE=9600
SERIAL_DATA_BITS=8
SERIAL_PARITY=none
SERIAL_STOP_BITS=1

# Set to true to use simulated serial port (for development without physical scale)
SIMULATE_SERIAL=false

# Weight API
WEIGHT_API_PORT=5000

# Stability Detection
STABILITY_THRESHOLD_MS=1500   # ms of consistent readings to declare stable
STABILITY_TOLERANCE_KG=0.02   # max deviation (kg) to consider "same" reading

# Logging
LOG_LEVEL=info
